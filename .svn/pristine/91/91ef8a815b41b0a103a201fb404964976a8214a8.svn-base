extends Node

# [AssetLoader] Autoload全局加载脚本
# 全局外部资源加载器，用于统一管理图片、音频、视频等外部资源加载与路径配置
# 适用于：外部资源热更新 / 展厅展示系统 / UI动态换图 / 多媒体播放系统
#
# 功能：
# - 自动读取 config.ini 配置外部资源根路径
# - 支持图片 / 音频 / 视频统一路径管理
# - 图片加载带缓存机制（避免重复加载）
# - 支持 Windows 打包后外部资源替换
#
# 使用方式：配合config_loader脚本使用，读取data/config.ini 来加载拼接路径
# [AssetLoader]
# base_path=C:\Users\Administrator
# image_dir=\Pictures\4K
# audio_dir=\Music\
# video_dir=\Videos\
#
# 【图片】
# $TextureRect.texture = AssetLoader.load_texture("logo.png")
# 【音频】
# $AudioStreamPlayer.stream = AssetLoader.load_audio("获得.mp3")
# $AudioStreamPlayer.play()
# 【视频（VideoStreamPlayer + FFmpeg 插件）】
# $VideoStreamPlayer.stream = AssetLoader.load_video_stream("待机.mp4")
# $VideoStreamPlayer.play()

var base_path: String = "C:/MyApp/media/"
var image_dir: String = "images"
var audio_dir: String = "audio"
var video_dir: String = "video"

var _texture_cache: Dictionary = {}


# 启动时自己读 config.ini
func _ready() -> void:
	_load_from_config()
	print("[AssetLoader] base_path = ", base_path)
	print("[AssetLoader] image_dir = ", image_dir)

# 修复 ini 行（自动补引号 / 过滤类型）
func _load_from_config() -> void:
	var config_path: String
	if OS.has_feature("editor"):
		config_path = "res://data/config.ini"
	else:
		config_path = OS.get_executable_path().get_base_dir() + "/data/config.ini"

	if not FileAccess.file_exists(config_path):
		push_error("[AssetLoader] 未找到 config.ini: " + config_path)
		return

	var file := FileAccess.open(config_path, FileAccess.READ)
	if not file:
		return
	var raw := file.get_as_text().replace("\\", "/")
	file.close()

	# 逐行补引号（复用相同逻辑）
	var lines := raw.split("\n")
	var fixed: PackedStringArray = []
	for line in lines:
		fixed.append(_fix_ini_line(line))
	raw = "\n".join(fixed)

	var cfg := ConfigFile.new()
	if cfg.parse(raw) != OK:
		push_error("[AssetLoader] config.ini 解析失败")
		return

	if not cfg.has_section("AssetLoader"):
		push_error("[AssetLoader] config.ini 中没有 [AssetLoader] 小节")
		return

	base_path = cfg.get_value("AssetLoader", "base_path", base_path)
	image_dir = cfg.get_value("AssetLoader", "image_dir", image_dir)
	audio_dir = cfg.get_value("AssetLoader", "audio_dir", audio_dir)
	video_dir = cfg.get_value("AssetLoader", "video_dir", video_dir)

# 修复 ini 行（自动补引号 / 过滤类型）
func _fix_ini_line(line: String) -> String:
	var stripped := line.strip_edges()
	if stripped.begins_with(";") or stripped.begins_with("#") \
	or stripped.begins_with("[") or stripped == "":
		return line
	var eq_pos := line.find("=")
	if eq_pos == -1:
		return line
	var key := line.substr(0, eq_pos).strip_edges()
	var val := line.substr(eq_pos + 1).strip_edges()
	if val.begins_with('"') or val.begins_with("'"):
		return line
	if val == "true" or val == "false":
		return line
	if val.is_valid_float() or val.is_valid_int():
		return line
	if val == "":
		return key + ' = ""'
	return key + ' = "' + val + '"'

# 路径构建
func _build_path(sub_dir: String, file_name: String) -> String:
	var base := base_path.replace("\\", "/").strip_edges()
	if not base.ends_with("/"):
		base += "/"
	if sub_dir == "":
		return base + file_name
	return base + sub_dir + "/" + file_name

func get_image_path(file_name: String) -> String:
	return _build_path(image_dir, file_name)

func get_audio_path(file_name: String) -> String:
	return _build_path(audio_dir, file_name)

func get_video_path(file_name: String) -> String:
	return _build_path(video_dir, file_name)

# 图片加载（带缓存）
func load_texture(file_name: String) -> Texture2D:
	if _texture_cache.has(file_name):
		return _texture_cache[file_name]
	var path := get_image_path(file_name)
	if not FileAccess.file_exists(path):
		push_error("[AssetLoader] 图片不存在: " + path)
		return null
	var img := Image.new()
	if img.load(path) != OK:
		push_error("[AssetLoader] 图片加载失败: " + path)
		return null
	var tex := ImageTexture.create_from_image(img)
	_texture_cache[file_name] = tex
	return tex

# 清理缓存
func clear_cache() -> void:
	_texture_cache.clear()

# 音频加载
func load_audio(file_name: String) -> AudioStream:
	var path := get_audio_path(file_name)
	if not FileAccess.file_exists(path):
		push_error("[AssetLoader] 音频不存在: " + path)
		return null
	match file_name.get_extension().to_lower():
		"ogg": return AudioStreamOggVorbis.load_from_file(path)
		"wav": return AudioStreamWAV.load_from_file(path)
		"mp3": return AudioStreamMP3.load_from_file(path)
	push_error("[AssetLoader] 不支持的格式: " + file_name)
	return null

# 视频加载（EIRTeam.FFmpeg）
func load_video_stream(file_name: String) -> VideoStream:
	var path := get_video_path(file_name)
	if not FileAccess.file_exists(path):
		push_error("[AssetLoader] 视频不存在: " + path)
		return null
	var stream := FFmpegVideoStream.new()
	stream.file = path
	return stream
