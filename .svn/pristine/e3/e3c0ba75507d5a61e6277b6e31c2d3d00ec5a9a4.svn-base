# 你的场景脚本
func _ready() -> void:
	$TextureRect.texture = AssetLoader.load_texture("摩托.jpg")
	$TextureRect2.texture = AssetLoader.load_texture("4K-3840x2160 (2).jpg")
	$TextureRect3.texture = AssetLoader.load_texture("4K-3840x2160 (4).jpg")
	
	$AudioStreamPlayer.stream = AssetLoader.load_audio("sfx_获得.mp3")
	
	$VideoStreamPlayer.stream = AssetLoader.load_video_stream("1升仙台待机.mp4")

func _on_button_pressed() -> void:
	$AudioStreamPlayer.play()
	
func _on_button_2_pressed() -> void:
	$VideoStreamPlayer.play()
