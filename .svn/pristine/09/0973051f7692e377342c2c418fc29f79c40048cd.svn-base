class_name AssetLoader
extends Node
## [b]全局外部资源加载器 (AssetLoader)[/b]
##
## 该组件允许从可执行文件同级目录动态加载图片、音频和视频。
## 支持自动缓存图片以提升性能。
##
## [b]1. 加载图片 (TextureRect/Sprite2D):[/b]
## [codeblock]
## # 自动加载并缓存图片
## texture_rect.texture = AssetLoader.instance.load_texture("logo.png")
## [/codeblock]
##
## [b]2. 播放音频 (AudioStreamPlayer):[/b]
## [codeblock]
## # 支持 .mp3, .wav, .ogg 格式
## audio_player.stream = AssetLoader.instance.load_audio("bgm.mp3")
## audio_player.play()
## [/codeblock]
##
## [b]3. 播放视频 (VideoStreamPlayer):[/b]
## [codeblock]
## # 获取完整路径并赋值给视频播放器
## var video_path = AssetLoader.instance.get_video_path("intro.mp4")
## video_player.stream = VideoStreamTheora.new() # 或者 VideoStreamPlayer 自动识别
## video_player.file = video_path
## video_player.play()
## [/codeblock]
##
## [color=#70ff81]注意：[/color]确保资源放在 [code]exe所在目录/data/...[/code] 对应的子文件夹中。

@export var data_dir: String = "data" ## 数据根目录
@export_group("Media") ## 媒体文件
@export var image_dir: String = "images" ## 图片
@export var audio_dir: String = "audio" ## 音频
@export var video_dir: String = "video" ## 视频

var _texture_cache := {} # 缓存

static var instance: AssetLoader # 单例引用

func _ready():
	instance = self

# ==============================
# 基础路径
# ==============================
func _base_dir() -> String:
	var exe_dir = OS.get_executable_path().get_base_dir()
	return exe_dir

func _build_path(sub_dir: String, file_name: String) -> String:
	var base = _base_dir()

	# data_dir 为空 → 直接 exe 目录
	if data_dir.strip_edges() == "":
		return base + "/" + sub_dir + "/" + file_name

	return base + "/" + data_dir + "/" + sub_dir + "/" + file_name

# ==============================
# 图片
# ==============================
func get_image_path(file_name: String) -> String:
	return _build_path(image_dir, file_name)

func load_texture(file_name: String) -> Texture2D:
	if _texture_cache.has(file_name):
		return _texture_cache[file_name]

	var path = get_image_path(file_name)

	if not FileAccess.file_exists(path):
		push_error("图片不存在: " + path)
		return null

	var img := Image.new()
	if img.load(path) != OK:
		push_error("图片加载失败: " + path)
		return null

	var tex = ImageTexture.create_from_image(img)
	_texture_cache[file_name] = tex
	return tex

# ==============================
# 音频（支持 wav / mp3 / ogg）
# ==============================
func load_audio(file_name: String) -> AudioStream:
	var path = _build_path(audio_dir, file_name)

	if not FileAccess.file_exists(path):
		push_error("音频不存在: " + path)
		return null

	if file_name.ends_with(".ogg"):
		return AudioStreamOggVorbis.load_from_file(path)

	elif file_name.ends_with(".wav"):
		return AudioStreamWAV.load_from_file(path)

	elif file_name.ends_with(".mp3"):
		return AudioStreamMP3.load_from_file(path)

	else:
		push_error("不支持的音频格式: " + file_name)
		return null

# ==============================
# 视频（mp4）
# ==============================
func get_video_path(file_name: String) -> String:
	return _build_path(video_dir, file_name)
